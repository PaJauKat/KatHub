<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="KatHub.MainWindow"
    Title="KatHub"
    Height="500"
    Width="800"
    WindowStartupLocation="CenterScreen"
    Background="#0f0f13"
    ResizeMode="NoResize"
    Loaded="Window_Loaded">

    <Grid>

        <!-- Background subtle gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0f0f13" Offset="0"/>
                <GradientStop Color="#15151c" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Title -->
        <TextBlock Text="KatHub"
                FontSize="28"
                Foreground="#e63946"
                Margin="20,20,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                FontWeight="Bold"/>

        <!-- Subtitle -->
        <TextBlock Text="Private Plugin Suite"
                FontSize="12"
                Foreground="#888"
                Margin="22,60,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"/>


        <!-- Main Panel -->
        <Border Background="#1a1a22"
            CornerRadius="10"
            Margin="20,100,20,20"
            Padding="20">

            <StackPanel>

                <!-- KatPlugins -->
                <Border Background="#23232d"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,10">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="KatPlugins"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="DemiBold"
                            VerticalAlignment="Center"
                            Grid.Column="0" />

                        <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                            <Button x:Name="UninstallKatButton"
                                    Content="" 
                                    Visibility="Collapsed"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="14"
                                    Width="30"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    Background="#2a2a35"
                                    Foreground="#888"
                                    BorderThickness="0"
                                    ToolTip="Uninstall Plugins"
                                    Cursor="Hand"
                                    Click="UninstallKatButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="15"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#e63946"/>
                                                <Setter Property="Background" Value="#32323d"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <TextBlock x:Name="KatPluginsStatusLabel"
                                Text="Installed ✔"
                                Foreground="LightGreen"
                                VerticalAlignment="Center"
                                Visibility="Visible"
                                FontWeight="SemiBold"
                                Margin="0,0,8,0" />
                            <Button Content="Install"
                                x:Name="KatPluginsMainButton"
                                Width="100"
                                Height="30"
                                Background="#e63946"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="KatPluginsMainButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <ProgressBar x:Name="KatProgressBar" 
                                 Height="4" 
                                 Foreground="#e63946" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Minimum="0" 
                                 Maximum="100"
                                 Visibility="Collapsed"
                                 Margin="0,2,8,0"/>

                        </StackPanel>
                    </Grid>

                </Border>

                <!-- Account Manager -->
                <Border Background="#23232d"
                    CornerRadius="8"
                    Padding="15">

                    <Grid>

                        <TextBlock Text="KatAccountManager"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="DemiBold"
                                VerticalAlignment="Center"/>

                        <Button Content="Unavailable"
                            Width="100"
                            Height="30"
                            HorizontalAlignment="Right"
                            Background="#2a2a35"
                            Foreground="#888"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenAccountManager_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                    </Grid>

                </Border>

                <Border Background="#23232d"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,10,0,0">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="LOL config locker"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="DemiBold"
                                VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                            <TextBlock x:Name="LolConfigLockerStatusLabel"
                                Text="Unlocked"
                                Foreground="LightCoral"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Margin="0,0,8,0" />

                            <Button Content="Lock"
                                x:Name="LolConfigLockerButton"
                                Width="100"
                                Height="30"
                                HorizontalAlignment="Right"
                                Background="#e63946"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="LolConfigLocker_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>


            </StackPanel>

        </Border>

    </Grid>

</Window>